{
  "expo": {
    "name": "取件通",
    "slug": "PickupApp",
    "version": "1.0.0",
    "scheme": "pickupapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carl.pickupapp"
    },
    "android": {
      "package": "com.carl.pickupapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECEIVE_SMS",
        "READ_SMS",
        "INTERNET",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "./plugins/withAndroidManifest.js",
      "./plugins/withMainActivity.js",
      "expo-sharing",
      "expo-image-picker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "146887cd-4aba-4c7b-82ef-5de2da3e6d4c"
      }
    },
    "owner": "skyreey"
  }
}
